# ─────────────────────────────────────────────────────────────────────────────
# Firebase Configuration
# Copiá este archivo como `.env` y completá cada valor con los datos de tu
# proyecto: Firebase Console → tu proyecto → ⚙ Configuración → Tus apps → SDK
# ─────────────────────────────────────────────────────────────────────────────

# Clave de API pública de tu app web
VITE_FIREBASE_API_KEY=AIzaSy_TU_API_KEY_AQUI

# Dominio de autenticación (generalmente <proyecto>.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto-id.firebaseapp.com

# ID del proyecto en Firebase
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id

# Bucket de Storage (generalmente <proyecto>.appspot.com)
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto-id.appspot.com

# Sender ID de Cloud Messaging
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000

# App ID (formato: 1:<sender_id>:web:<hash>)
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# ─────────────────────────────────────────────────────────────────────────────
# Legacy — Google Apps Script (mantener hasta completar la migración)
# ─────────────────────────────────────────────────────────────────────────────
# VITE_API_URL=https://script.google.com/macros/s/TU_ID_AQUI/exec

# Clave de acceso (auth simple, reemplazar por Firebase Auth en el futuro)
VITE_ACCESS_KEY=arriba2026
